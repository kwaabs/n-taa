# ─────────────────────────────────────────────
# Postgres (supabase/postgres image)
# ─────────────────────────────────────────────
# The supabase image's superuser is `supabase_admin`.
# We expose Postgres on a non-default port (5440).
POSTGRES_PASSWORD=geo_dev_pw
POSTGRES_DB=geo
POSTGRES_HOST_PORT=5440

# Application DB role (created in bootstrap.sql)
APP_DB_USER=geo_app
APP_DB_PASSWORD=geo_app_dev_pw

# ─────────────────────────────────────────────
# Martin tile server
# ─────────────────────────────────────────────
MARTIN_HOST_PORT=5441

# ─────────────────────────────────────────────
# Go API (Step 2 — reserved)
# ─────────────────────────────────────────────
API_HOST_PORT=5442



AZURE_TENANT_ID=<your ECGGH tenant id>
AZURE_CLIENT_ID=<from Azure App Registration>
AZURE_CLIENT_SECRET=<from Azure App Registration>
AZURE_REDIRECT_URI=http://localhost:3000/auth/azure/callback
