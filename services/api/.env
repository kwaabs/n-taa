# ─────────────────────────────────────────────
# Go API
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5442
API_ENV=development               # development | production
API_LOG_LEVEL=info                # debug | info | warn | error

# ─────────────────────────────────────────────
# Database
# Connects as the application role created in bootstrap.sql.
# ─────────────────────────────────────────────
DATABASE_URL=postgres://geo_app:geo_app_dev_pw@localhost:5440/geo?sslmode=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# ─────────────────────────────────────────────
# CORS (comma-separated)
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
# Generate a strong random string for prod. Any 32+ char string works for dev.
JWT_SIGNING_KEY=dev-super-secret-change-me-please-32bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=geo-app

# Superuser seeded on boot (idempotent). Comment out to skip seeding.
SUPERUSER_EMAIL=admin@geo.local
SUPERUSER_PASSWORD=change-me-now
SUPERUSER_NAME=Super Admin

# Refresh cookie (HttpOnly). Set Secure=true when serving over HTTPS.
COOKIE_DOMAIN=
COOKIE_SECURE=false


AZURE_TENANT_ID=711b8fff-9db3-42cc-bc27-7a19ced91f39
AZURE_CLIENT_ID=1baf5f62-89bd-4089-9c4e-70ca0009ebad
AZURE_CLIENT_SECRET=aa38a74a-d7c4-42fc-b0b1-8b7771e73e07
AZURE_REDIRECT_URI=http://localhost:3000
