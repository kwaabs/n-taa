# ─────────────────────────────────────────────
# Go API
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5442
API_ENV=development               # development | production
API_LOG_LEVEL=info                # debug | info | warn | error

# ─────────────────────────────────────────────
# Database
# Connects as the application role created in bootstrap.sql.
# ─────────────────────────────────────────────
DATABASE_URL=postgres://geo_app:geo_app_dev_pw@localhost:5440/geo?sslmode=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# ─────────────────────────────────────────────
# CORS (comma-separated)
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
