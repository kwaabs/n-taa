# ─── Postgres ─────────────────────────────────────────────
POSTGRES_DB=geo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_SUPABASE_ADMIN_PW
APP_DB_USER=geo_app
APP_DB_PASSWORD=CHANGE_ME_STRONG_APP_USER_PW

# ─── API ──────────────────────────────────────────────────
API_ENV=production
API_LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=5442

DATABASE_URL=postgres://geo_app:CHANGE_ME_STRONG_APP_USER_PW@postgres:5432/geo?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# Frontend origin(s) that will call this API. Comma-separated.
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost

# ─── Auth ─────────────────────────────────────────────────
# Generate a 32+ char random string: `openssl rand -base64 48`
JWT_SIGNING_KEY=CHANGE_ME_32_PLUS_CHAR_RANDOM_STRING_FOR_JWT
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=geo-app

# ─── Superuser seed (applied at boot, idempotent) ─────────
SUPERUSER_EMAIL=admin@your-domain.com
SUPERUSER_PASSWORD=CHANGE_ME_STRONG_ADMIN_PW
SUPERUSER_NAME=Administrator

# ─── Cookies ──────────────────────────────────────────────
# Set to your domain in prod; leave empty for localhost testing
COOKIE_DOMAIN=
COOKIE_SECURE=false
